APP_NAME = "Grim Reaper"
APP_VERSION = "3.0"

SUPPORTED_EXT = (
    ".xlsx", ".xls", ".csv",
    ".docx", ".doc",
    ".pdf", ".txt"
)

FILE_FILTER = (
    "Supported Files (*.xlsx *.xls *.csv *.docx *.doc *.pdf *.txt);;"
